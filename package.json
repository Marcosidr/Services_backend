{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "dev:test": "npx dotenv-cli -e .env.test -- ts-node --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "npx dotenv-cli -e .env -- sequelize-cli db:migrate --env development",
    "db:migrate:test": "npx dotenv-cli -e .env.test -- sequelize-cli db:migrate --env test",
    "db:migrate:undo": "npx dotenv-cli -e .env -- sequelize-cli db:migrate:undo --env development",
    "db:migrate:status": "npx dotenv-cli -e .env -- sequelize-cli db:migrate:status --env development",
    "test": "npx dotenv-cli -e .env.test -- jest --runInBand --passWithNoTests",
    "test:watch": "npx dotenv-cli -e .env.test -- jest --watch --passWithNoTests",
    "test:coverage": "npx dotenv-cli -e .env.test -- jest --coverage --passWithNoTests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcosidr/Services_backend.git"
  },
  "bugs": {
    "url": "https://github.com/Marcosidr/Services_backend/issues"
  },
  "homepage": "https://github.com/Marcosidr/Services_backend#readme"
}
